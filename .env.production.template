# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PRODUCTION ENVIRONMENT VARIABLES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ═══════════════════════════════════════════
# 🔐 CRITICAL SECURITY (REQUIRED)
# ═══════════════════════════════════════════

# Environment mode
NODE_ENV=production

# Webhook secret for conversion tracking
# ⚠️ MUST BE STRONG - Use at least 32 random characters
WEBHOOK_SECRET=your_super_secure_webhook_secret_here_minimum_32_chars

# JWT secret for authentication
# ⚠️ MUST BE STRONG - Use at least 64 random characters
JWT_SECRET=your_super_secure_jwt_secret_here_minimum_64_chars

# ═══════════════════════════════════════════
# 💾 DATABASE (REQUIRED)
# ═══════════════════════════════════════════

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://username:password@host:5432/lonaat

# ═══════════════════════════════════════════
# 🚫 MANUAL PRODUCTS MODE (REQUIRED)
# ═══════════════════════════════════════════

# Disable auto product import for production stability
# Set to 'true' to prevent API spam and silent failures
MANUAL_PRODUCTS_ONLY=true

# ═══════════════════════════════════════════
# 🌐 SERVER CONFIGURATION
# ═══════════════════════════════════════════

# Server port
PORT=4000

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.com

# Backend URL
BACKEND_URL=https://your-backend-domain.com

# ═══════════════════════════════════════════
# 💳 PAYMENT GATEWAY (OPTIONAL)
# ═══════════════════════════════════════════

# MTN MoMo API credentials
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_mtn_api_user
MTN_API_KEY=your_mtn_api_key
MTN_ENVIRONMENT=production

# ═══════════════════════════════════════════
# 🤖 AI SERVICES (OPTIONAL)
# ═══════════════════════════════════════════

# OpenAI API key for ad generation
OPENAI_API_KEY=your_openai_api_key

# ═══════════════════════════════════════════
# 📧 EMAIL SERVICE (OPTIONAL)
# ═══════════════════════════════════════════

# Email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# ═══════════════════════════════════════════
# 📊 MONITORING & LOGGING (OPTIONAL)
# ═══════════════════════════════════════════

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Sentry DSN for error tracking
SENTRY_DSN=your_sentry_dsn

# ═══════════════════════════════════════════
# 🔧 ADVANCED CONFIGURATION (OPTIONAL)
# ═══════════════════════════════════════════

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session configuration
SESSION_SECRET=your_session_secret

# Cookie settings
COOKIE_DOMAIN=.your-domain.com
COOKIE_SECURE=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📝 NOTES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1. Copy this file to .env in production
# 2. Replace ALL placeholder values with real credentials
# 3. NEVER commit .env to version control
# 4. Use strong random strings for secrets (use: openssl rand -base64 64)
# 5. Keep MANUAL_PRODUCTS_ONLY=true for stable production deployment

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔒 SECURITY CHECKLIST
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ✅ WEBHOOK_SECRET is at least 32 characters
# ✅ JWT_SECRET is at least 64 characters
# ✅ DATABASE_URL uses strong password
# ✅ MANUAL_PRODUCTS_ONLY=true
# ✅ NODE_ENV=production
# ✅ All secrets are unique (not default values)
# ✅ .env file is in .gitignore
# ✅ File permissions are restricted (chmod 600 .env)
