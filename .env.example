# Example environment variables for Node backend
# copy this to .env in the project root and customize

# database URL (Docker PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/lonaat

# secrets
JWT_SECRET=your_jwt_secret
NETWORK_CREDENTIAL_SECRET=some_random_key

# platform affiliate id used by many adapters
PLATFORM_AFF_ID=PLATFORM

# digistore dynamic redirect values (required for /track endpoint)
DIGISTORE_PRODUCT_ID=YOUR_PRODUCT_ID
DIGISTORE_AFFILIATE_ID=YOUR_AFFILIATE_ID

# secret key that must be sent by the Digistore webhook when hitting /webhook/digistore
DIGISTORE_WEBHOOK_SECRET=your_secret_key_here

# Affiliate Network API Credentials (for product import)
# Admitad (Priority Network)
ADMITAD_TOKEN=your_admitad_api_token_here
ADMITAD_API_URL=https://api.admitad.com/products

# AliExpress
ALIEXPRESS_TOKEN=your_aliexpress_api_token_here
ALIEXPRESS_API_URL=https://api.aliexpress.com/products

# Digistore24
DIGISTORE_TOKEN=your_digistore_api_token_here
DIGISTORE_API_URL=https://www.digistore24.com/api/products

# other optional keys go here
