entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["sh", "-c", "cd backend && gunicorn --bind 0.0.0.0:5000 --reuse-port --workers 2 --timeout 120 main:app"]
deploymentTarget = "autoscale"

[agent]
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Server"

[[workflows.workflow]]
name = "Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && python main.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 35591
externalPort = 80

[[ports]]
localPort = 41329
externalPort = 4200

[[ports]]
localPort = 42271
externalPort = 3001

[[ports]]
localPort = 42331
externalPort = 3002

[[ports]]
localPort = 44089
externalPort = 3000

[[ports]]
localPort = 45843
externalPort = 3003
