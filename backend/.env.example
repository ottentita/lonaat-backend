# Flask Configuration
FLASK_SECRET=your_flask_secret_key_here
JWT_SECRET=your_jwt_secret_key_here

# Database (SQLite for development, PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Flutterwave Payment Gateway
FLUTTERWAVE_SECRET=your_flutterwave_secret
FLUTTERWAVE_PUBLIC=your_flutterwave_public

# Application Settings
BASE_URL=https://lonaat.replit.app
ADMIN_EMAIL=admin@example.com

# Legacy Admin Credentials (for backward compatibility)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure_password_here

# Firebase (optional - for backward compatibility)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Affiliate Networks (optional)
# CLICKBANK_AFFILIATE_ID=your_affiliate_id
# SHAREASALE_TOKEN=your_token
# SHAREASALE_SECRET=your_secret
# SHAREASALE_AFFILIATE_ID=your_affiliate_id
# DIGISTORE24_API_KEY=your_api_key
