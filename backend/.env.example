# ========================================
# LONAAT ENVIRONMENT VARIABLES
# Copy to .env and fill in your values
# NEVER commit .env to version control!
# ========================================

# ========================================
# CRITICAL DEPLOYMENT SECRETS (Required)
# ========================================

# Database Connection (Required for Production)
DATABASE_URL=postgresql://user:password@host:port/database
# Example: postgresql://lonaat_user:xxxxx@dpg-xxxxx.oregon-postgres.render.com/lonaat_db
# Development fallback: sqlite:///app.db (auto-used if DATABASE_URL not set)

# Encryption Key (Auto-generated if not set, but SET THIS FOR PRODUCTION!)
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here
# Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"

# Flask Secret Key (Required)
FLASK_SECRET=your-long-random-secret-key-here
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# JWT Secret Key (Optional - defaults to FLASK_SECRET)
JWT_SECRET_KEY=your-jwt-secret-key-here

# Admin Credentials (Required for admin access)
ADMIN_USERNAME=admin@lonaat.com
ADMIN_PASSWORD=your-strong-admin-password-here
ADMIN_EMAIL=admin@lonaat.com

# ========================================
# EMAIL CONFIGURATION (SMTP)
# Required for user notifications
# ========================================

# Email Service Provider (Brevo free tier: 300 emails/day)
EMAIL_HOST=smtp-relay.sendinblue.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-username-here
EMAIL_PASS=your-smtp-password-here
EMAIL_SENDER=Lonaat Support <no-reply@lonaat.com>

# Alternative providers:
# Mailgun: EMAIL_HOST=smtp.mailgun.org, EMAIL_PORT=587
# SendGrid: EMAIL_HOST=smtp.sendgrid.net, EMAIL_PORT=587

# ========================================
# AFFILIATE NETWORK API KEYS
# ========================================

# Amazon Product Advertising API (PA-API 5.0)
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_ASSOC_TAG=your-amazon-associate-tag

# ShareASale
SHAREASALE_TOKEN=your-shareasale-api-token
SHAREASALE_SECRET=your-shareasale-secret
SHAREASALE_AFFILIATE_ID=your-shareasale-affiliate-id

# CJ Affiliate (Commission Junction)
CJ_TOKEN=your-cj-api-token

# Impact Radius
IMPACT_TOKEN=your-impact-api-token
IMPACT_ACCOUNT_SID=your-impact-account-sid

# Admitad
ADMITAD_TOKEN=your-admitad-api-token

# African Affiliate Networks
AFRIEX_TOKEN=your-afriex-api-token
KALAWEB_API_KEY=your-kalaweb-api-key
PAYSALE_TOKEN=your-paysale-api-token
NALAREF_TOKEN=your-nalaref-api-token
GREY_TOKEN=your-grey-api-token
TRADETRACKER_TOKEN=your-tradetracker-api-token

# ========================================
# OPTIONAL CONFIGURATIONS
# ========================================

# Firebase (Optional - for legacy data storage)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"..."}'

# Application Base URL
BASE_URL=https://lonaat.replit.app

# Fraud Detection (Optional - defaults shown)
MAX_WITHDRAWALS_PER_DAY=3
MAX_COMMISSIONS_PER_PRODUCT_PER_MIN=5
FRAUD_DETECTION_ENABLED=True
