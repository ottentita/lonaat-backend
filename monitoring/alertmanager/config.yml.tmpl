global:
  resolve_timeout: 5m

route:
  receiver: 'composite'
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 3h

receivers:
  - name: 'email'
    email_configs:
      - to: '${ALERT_EMAIL}'
        from: 'alertmanager@${SMTP_HOST}'
        smarthost: '${SMTP_HOST}:${SMTP_PORT}'
        auth_username: '${SMTP_USER}'
        auth_password: '${SMTP_PASSWORD}'
        send_resolved: true

  - name: 'webhook'
    webhook_configs:
      - url: 'http://webhook-receiver:5001/'
        send_resolved: true

  - name: 'composite'
    # forward to both email and webhook
    webhook_configs:
      - url: 'http://webhook-receiver:5001/'
        send_resolved: true
    email_configs:
      - to: '${ALERT_EMAIL}'
        from: 'alertmanager@${SMTP_HOST}'
        smarthost: '${SMTP_HOST}:${SMTP_PORT}'
        auth_username: '${SMTP_USER}'
        auth_password: '${SMTP_PASSWORD}'
        send_resolved: true

# End of template - values are substituted from environment variables at container start
