{
  "name": "lonaat-backend",
  "version": "1.0.0",
  "description": "Lonaat Affiliate Marketing Platform - Node.js Backend",
  "main": "dist/index.build.js",
  "scripts": {
    "preinstall": "node scripts/check-node-version.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "test": "vitest",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node src/seed.ts",
    "seed:admin": "ts-node prisma/seeds/adminSeed.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.build.js"
  },
  "dependencies": {
    "@prisma/client": "^4.16.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "openai": "^6.15.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.11",
    "prisma": "^4.16.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18",
    "semver": "^7.7.4"
  },
  "engines": {
    "node": ">=18 <22"
  },
  "engineStrict": true,
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
