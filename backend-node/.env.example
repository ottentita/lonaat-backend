# Example environment variables for Node backend
# copy this to .env in the project root and customize

# database URL (sqlite for dev or postgres in prod)
DATABASE_URL="file:./dev.db"

# secrets
JWT_SECRET=your_jwt_secret
NETWORK_CREDENTIAL_SECRET=some_random_key

# platform affiliate id used by many adapters
PLATFORM_AFF_ID=PLATFORM

# digistore dynamic redirect values (required for /track endpoint)
DIGISTORE_PRODUCT_ID=YOUR_PRODUCT_ID
DIGISTORE_AFFILIATE_ID=YOUR_AFFILIATE_ID

# secret key that must be sent by the Digistore webhook when hitting /webhook/digistore
DIGISTORE_WEBHOOK_SECRET=your_secret_key_here

# other optional keys go here
