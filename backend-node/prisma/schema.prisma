generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(120)
  password_hash String    @db.VarChar(255)
  role          String    @default("user") @db.VarChar(20)
  balance       Float     @default(0)
  verified      Boolean   @default(false)
  referral_code String    @unique @db.VarChar(20)
  referred_by   String?   @db.VarChar(20)
  created_at    DateTime  @default(now())
  is_admin      Boolean   @default(false)
  is_active     Boolean   @default(true)
  is_blocked    Boolean   @default(false)
  blocked_until DateTime?
  block_reason  String?   @db.VarChar(255)

  transactions       Transaction[]
  commissions        Commission[]
  withdrawals        WithdrawalRequest[]
  ad_boosts          AdBoost[]
  products           Product[]
  network_connections NetworkConnection[]
  notifications      Notification[]
  ai_jobs            AIJob[]
  credit_wallet      CreditWallet?

  @@map("users")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  user_id     Int
  type        String   @db.VarChar(50)
  amount      Float
  status      String   @default("pending") @db.VarChar(20)
  description String?  @db.Text
  extra_data  Json?    @db.JsonB
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("transactions")
}

model Commission {
  id           Int      @id @default(autoincrement())
  user_id      Int
  amount       Float
  source       String   @db.VarChar(100)
  status       String   @default("pending") @db.VarChar(20)
  network      String?  @db.VarChar(50)
  product_id   Int?
  webhook_data Json?    @db.JsonB
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("commissions")
}

model WithdrawalRequest {
  id               Int      @id @default(autoincrement())
  user_id          Int
  amount           Float
  status           String   @default("pending") @db.VarChar(20)
  payment_method   String   @db.VarChar(50)
  payment_details  String?  @db.Text
  processed_at     DateTime?
  rejection_reason String?  @db.Text
  created_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("withdrawal_requests")
}

model AdBoost {
  id                  Int       @id @default(autoincrement())
  user_id             Int
  product_id          Int?
  boost_level         Int       @default(1)
  credits_spent       Int       @default(0)
  clicks_received     Int       @default(0)
  status              String    @default("active") @db.VarChar(20)
  started_at          DateTime  @default(now())
  expires_at          DateTime?
  imported_product_id Int?
  boost_type          String?   @db.VarChar(50)
  is_admin_campaign   Boolean   @default(false)
  campaign_config     Json?     @db.JsonB

  user User @relation(fields: [user_id], references: [id])

  @@map("ad_boosts")
}

model Product {
  id             Int      @id @default(autoincrement())
  user_id        Int?
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  price          String?  @db.VarChar(100)
  affiliate_link String?  @db.Text
  network        String?  @db.VarChar(50)
  category       String?  @db.VarChar(100)
  image_url      String?  @db.Text
  extra_data     Json?    @db.JsonB
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@map("products")
}

model NetworkConnection {
  id           Int      @id @default(autoincrement())
  user_id      Int
  network      String   @db.VarChar(50)
  api_key      String?  @db.Text
  api_secret   String?  @db.Text
  access_token String?  @db.Text
  is_active    Boolean  @default(true)
  last_sync    DateTime?
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("network_connections")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(255)
  message    String   @db.Text
  type       String   @default("info") @db.VarChar(50)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model AIJob {
  id         Int      @id @default(autoincrement())
  user_id    Int
  job_type   String   @db.VarChar(50)
  status     String   @default("pending") @db.VarChar(20)
  input_data Json?    @db.JsonB
  result     Json?    @db.JsonB
  error      String?  @db.Text
  created_at DateTime @default(now())
  completed_at DateTime?

  user User @relation(fields: [user_id], references: [id])

  @@map("ai_jobs")
}

model CreditWallet {
  id              Int      @id @default(autoincrement())
  user_id         Int      @unique
  credits         Int      @default(0)
  total_purchased Int      @default(0)
  total_spent     Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("credit_wallets")
}

model CreditPackage {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  credits     Int
  price       Float
  bonus       Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("credit_packages")
}

model Plan {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(100)
  price          Float
  duration_days  Int
  credits        Int      @default(0)
  features       Json?    @db.JsonB
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id         Int       @id @default(autoincrement())
  user_id    Int
  plan_id    Int
  status     String    @default("active") @db.VarChar(20)
  starts_at  DateTime  @default(now())
  expires_at DateTime?
  created_at DateTime  @default(now())

  plan Plan @relation(fields: [plan_id], references: [id])

  @@map("subscriptions")
}

model PaymentRequest {
  id             Int      @id @default(autoincrement())
  user_id        Int
  amount         Float
  type           String   @db.VarChar(50)
  status         String   @default("pending") @db.VarChar(20)
  receipt_url    String?  @db.Text
  payment_method String?  @db.VarChar(50)
  notes          String?  @db.Text
  processed_at   DateTime?
  created_at     DateTime @default(now())

  @@map("payment_requests")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  action     String   @db.VarChar(100)
  entity     String?  @db.VarChar(50)
  entity_id  Int?
  details    Json?    @db.JsonB
  ip_address String?  @db.VarChar(45)
  created_at DateTime @default(now())

  @@map("audit_logs")
}
