generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(120)
  password_hash String    @db.VarChar(255)
  role          String    @default("user") @db.VarChar(20)
  balance       Float     @default(0)
  verified      Boolean   @default(false)
  referral_code String    @unique @db.VarChar(20)
  referred_by   String?   @db.VarChar(20)
  created_at    DateTime  @default(now())
  is_admin      Boolean   @default(false)
  is_active     Boolean   @default(true)
  is_blocked    Boolean   @default(false)
  blocked_until DateTime?
  block_reason  String?   @db.VarChar(255)
  ai_premium           Boolean   @default(false)
  ai_premium_expires   DateTime?
  ai_boosts_today      Int       @default(0)
  ai_boosts_reset_at   DateTime?
  fraud_score          Int       @default(0)
  last_ip              String?   @db.VarChar(45)
  withdrawable_balance Float     @default(0)
  trial_ends_at        DateTime?

  transactions        Transaction[]
  commissions         Commission[]
  withdrawals         WithdrawalRequest[]
  ad_boosts           AdBoost[]
  products            Product[]
  network_connections NetworkConnection[]
  notifications       Notification[]
  ai_jobs             AIJob[]
  credit_wallet       CreditWallet?
  real_estate         RealEstateProperty[]
  bank_account        BankAccount?
  affiliate_clicks    AffiliateClick[]

  @@map("users")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  user_id     Int
  type        String   @db.VarChar(50)
  amount      Float
  status      String   @default("pending") @db.VarChar(20)
  description String?  @db.Text
  extra_data  Json?    @db.JsonB
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("transactions")
}

model Commission {
  id               Int       @id @default(autoincrement())
  user_id          Int
  network          String?   @db.VarChar(50)
  product_id       Int?
  amount           Float
  status           String    @default("pending") @db.VarChar(20)
  external_ref     String?   @db.VarChar(255)
  webhook_data     Json?     @db.JsonB
  created_at       DateTime  @default(now())
  paid_at          DateTime?
  campaign_id      Int?
  rejection_reason String?   @db.Text
  approved_at      DateTime?
  approved_by      Int?

  user User @relation(fields: [user_id], references: [id])

  @@map("commissions")
}

model WithdrawalRequest {
  id               Int       @id @default(autoincrement())
  user_id          Int
  amount           Float
  status           String    @default("pending") @db.VarChar(20)
  payment_method   String    @default("bank_transfer") @db.VarChar(50)
  payment_details  String?   @db.Text
  bank_name        String?   @db.VarChar(100)
  account_number   String?   @db.VarChar(50)
  account_name     String?   @db.VarChar(100)
  bank_code        String?   @db.VarChar(20)
  bank_account_id  Int?
  processed_at     DateTime?
  processed_by     Int?
  paid_at          DateTime?
  paid_by          Int?
  admin_note       String?   @db.Text
  rejection_reason String?   @db.Text
  created_at       DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("withdrawal_requests")
}

model AdBoost {
  id                  Int       @id @default(autoincrement())
  user_id             Int
  product_id          Int?
  boost_level         Int       @default(1)
  credits_spent       Int       @default(0)
  clicks_received     Int       @default(0)
  status              String    @default("active") @db.VarChar(20)
  started_at          DateTime  @default(now())
  expires_at          DateTime?
  imported_product_id Int?
  boost_type          String?   @db.VarChar(50)
  is_admin_campaign   Boolean   @default(false)
  campaign_config     Json?     @db.JsonB
  auto_boost          Boolean   @default(true)
  boost_intensity     Int       @default(1)
  last_boost_at       DateTime?
  total_impressions   Int       @default(0)

  user User @relation(fields: [user_id], references: [id])

  @@map("ad_boosts")
}

model Product {
  id              Int      @id @default(autoincrement())
  user_id         Int?
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  price           String?  @db.VarChar(100)
  affiliate_link  String?  @db.Text
  network         String?  @db.VarChar(50)
  category        String?  @db.VarChar(100)
  image_url       String?  @db.Text
  extra_data      Json?    @db.JsonB
  ai_generated_ad String?  @db.Text
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@map("products")
}

model RealEstateProperty {
  id               Int       @id @default(autoincrement())
  user_id          Int?
  title            String    @db.VarChar(255)
  description      String?   @db.Text
  property_type    String?   @db.VarChar(50)
  transaction_type String    @default("sale") @db.VarChar(20)
  location         String?   @db.VarChar(255)
  region           String?   @db.VarChar(100)
  city             String?   @db.VarChar(100)
  neighborhood     String?   @db.VarChar(100)
  price            Decimal?  @db.Decimal(12, 2)
  currency         String    @default("XAF") @db.VarChar(10)
  price_negotiable Boolean   @default(true)
  bedrooms         Int?
  bathrooms        Int?
  area_sqft        Int?
  land_size_sqft   Int?
  floors           Int?
  parking_spaces   Int?
  year_built       Int?
  furnishing       String?   @db.VarChar(50)
  condition        String?   @db.VarChar(50)
  images           Json?     @db.JsonB
  videos           Json?     @db.JsonB
  documents        Json?     @db.JsonB
  amenities        Json?     @db.JsonB
  image_url        String?   @db.Text
  video_url        String?   @db.Text
  owner_name       String?   @db.VarChar(100)
  owner_phone      String?   @db.VarChar(50)
  owner_email      String?   @db.VarChar(100)
  owner_whatsapp   String?   @db.VarChar(50)
  owner_id_type    String?   @db.VarChar(50)
  owner_id_number  String?   @db.VarChar(100)
  affiliate_link   String?   @db.Text
  ai_generated_ad  String?   @db.Text
  status           String    @default("pending") @db.VarChar(20)
  is_featured      Boolean   @default(false)
  is_paid          Boolean   @default(false)
  listing_fee      Decimal?  @db.Decimal(10, 2)
  rejection_reason String?   @db.Text
  approved_at      DateTime?
  approved_by      Int?
  is_active        Boolean   @default(true)
  views_count      Int       @default(0)
  inquiries_count  Int       @default(0)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  user              User?                @relation(fields: [user_id], references: [id])
  property_payments PropertyPayment[]
  property_ads      PropertyAd[]

  @@map("real_estate_properties")
}

model PropertyPayment {
  id             Int      @id @default(autoincrement())
  user_id        Int
  property_id    Int
  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @default("XAF") @db.VarChar(10)
  payment_method String   @default("bank_transfer") @db.VarChar(50)
  payment_type   String   @default("listing_fee") @db.VarChar(50)
  receipt_url    String?  @db.Text
  receipt_filename String? @db.VarChar(255)
  status         String   @default("pending") @db.VarChar(20)
  reviewed_by    Int?
  reviewed_at    DateTime?
  review_note    String?  @db.Text
  created_at     DateTime @default(now())

  property RealEstateProperty @relation(fields: [property_id], references: [id])

  @@map("property_payments")
}

model PropertyAd {
  id          Int       @id @default(autoincrement())
  property_id Int
  campaign_id Int?
  boost_start DateTime  @default(now())
  boost_end   DateTime?
  is_active   Boolean   @default(true)
  clicks      Int       @default(0)
  impressions Int       @default(0)
  is_admin    Boolean   @default(false)
  created_at  DateTime  @default(now())

  property RealEstateProperty @relation(fields: [property_id], references: [id])

  @@map("property_ads")
}

model NetworkConnection {
  id           Int      @id @default(autoincrement())
  user_id      Int
  network      String   @db.VarChar(50)
  api_key      String?  @db.Text
  api_secret   String?  @db.Text
  access_token String?  @db.Text
  is_active    Boolean  @default(true)
  last_sync    DateTime?
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("network_connections")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(255)
  message    String   @db.Text
  type       String   @default("info") @db.VarChar(50)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model AIJob {
  id            Int       @id @default(autoincrement())
  user_id       Int
  job_type      String    @db.VarChar(50)
  status        String    @default("pending") @db.VarChar(20)
  entity_type   String?   @db.VarChar(50)
  entity_id     Int?
  input_data    Json?     @db.JsonB
  result        Json?     @db.JsonB
  error_message String?   @db.Text
  created_at    DateTime  @default(now())
  started_at    DateTime?
  completed_at  DateTime?

  user User @relation(fields: [user_id], references: [id])

  @@map("ai_jobs")
}

model CreditWallet {
  id              Int      @id @default(autoincrement())
  user_id         Int      @unique
  credits         Int      @default(0)
  total_purchased Int      @default(0)
  total_spent     Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("credit_wallets")
}

model CreditPackage {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  credits       Int
  price         Float
  bonus_credits Int      @default(0)
  is_active     Boolean  @default(true)
  display_order Int?
  created_at    DateTime @default(now())

  @@map("credit_packages")
}

model Plan {
  id                    Int      @id @default(autoincrement())
  name                  String   @db.VarChar(100)
  price                 Float
  duration_days         Int
  features              Json?    @db.JsonB
  max_products          Int?
  max_ad_boosts         Int?
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  priority_boost        Boolean  @default(false)
  commission_multiplier Float?   @default(1.0)
  credits               Int      @default(0)

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                Int       @id @default(autoincrement())
  user_id           Int
  plan_id           Int
  status            String    @default("active") @db.VarChar(20)
  started_at        DateTime  @default(now())
  expires_at        DateTime?
  auto_renew        Boolean   @default(false)
  payment_reference String?   @db.VarChar(255)

  plan Plan @relation(fields: [plan_id], references: [id])

  @@map("subscriptions")
}

model PaymentRequest {
  id                      Int       @id @default(autoincrement())
  user_id                 Int
  purpose                 String?   @db.VarChar(50)
  amount                  Float
  currency                String?   @default("USD") @db.VarChar(10)
  payment_method          String?   @db.VarChar(50)
  package_id              Int?
  credits_to_add          Int?
  plan_id                 Int?
  subscription_id         Int?
  receipt_url             String?   @db.Text
  receipt_filename        String?   @db.VarChar(255)
  status                  String    @default("pending") @db.VarChar(20)
  reviewed_by             Int?
  review_note             String?   @db.Text
  reviewed_at             DateTime?
  stripe_payment_intent_id String?  @db.VarChar(255)
  created_at              DateTime  @default(now())
  extra_data              Json?     @db.JsonB

  @@map("payment_requests")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(50)
  entity_id   Int?
  details     Json?    @db.JsonB
  ip_address  String?  @db.VarChar(45)
  fraud_score Int?     @default(0)
  flagged     Boolean  @default(false)
  created_at  DateTime @default(now())

  @@map("audit_logs")
}

model BankAccount {
  id                    Int      @id @default(autoincrement())
  user_id               Int      @unique
  bank_name             String   @db.VarChar(100)
  account_name          String   @db.VarChar(100)
  account_number_cipher String   @db.Text
  account_number_last4  String   @db.VarChar(4)
  country               String   @db.VarChar(50)
  swift_code            String?  @db.VarChar(20)
  routing_code          String?  @db.VarChar(50)
  is_verified           Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("bank_accounts")
}

/// Land Registry with PostGIS spatial support
/// Note: The 'geom' column (geometry(Polygon,4326)) is managed via raw SQL in gpsVerification.ts
/// See prisma/migrations/postgis/001_enable_postgis.sql for setup
model Land {
  id                Int       @id @default(autoincrement())
  title_number      String    @unique @db.VarChar(100)
  owner_id          Int?
  current_owner     String    @db.VarChar(255)
  owner_id_type     String?   @db.VarChar(50)
  owner_id_number   String?   @db.VarChar(100)
  region            String    @db.VarChar(100)
  city              String?   @db.VarChar(100)
  town              String?   @db.VarChar(100)
  neighborhood      String?   @db.VarChar(100)
  area_sqm          Decimal?  @db.Decimal(12, 2)
  polygon_coords    Json      @db.JsonB
  polygon_wkt       String?   @db.Text
  center_lat        Decimal?  @db.Decimal(10, 8)
  center_lng        Decimal?  @db.Decimal(11, 8)
  land_use          String?   @db.VarChar(50)
  status            String    @default("verified") @db.VarChar(20)
  is_locked         Boolean   @default(false)
  lock_reason       String?   @db.Text
  verification_date DateTime?
  verified_by       Int?
  purchase_date     DateTime?
  purchase_price    Decimal?  @db.Decimal(15, 2)
  currency          String    @default("XAF") @db.VarChar(10)
  seller_name       String?   @db.VarChar(255)
  seller_id_number  String?   @db.VarChar(100)
  documents         Json?     @db.JsonB
  notes             String?   @db.Text
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  property_id       Int?
  ownership_history LandOwnership[]
  audit_logs        LandAuditLog[]

  @@index([region, city])
  @@index([current_owner])
  @@map("lands")
}

model LandOwnership {
  id              Int       @id @default(autoincrement())
  land_id         Int
  owner_name      String    @db.VarChar(255)
  owner_id_type   String?   @db.VarChar(50)
  owner_id_number String?   @db.VarChar(100)
  user_id         Int?
  ownership_type  String    @default("full") @db.VarChar(50)
  status          String    @default("active") @db.VarChar(20)
  acquired_date   DateTime
  acquired_price  Decimal?  @db.Decimal(15, 2)
  currency        String    @default("XAF") @db.VarChar(10)
  seller_name     String?   @db.VarChar(255)
  seller_id       String?   @db.VarChar(100)
  transfer_date   DateTime?
  transferred_to  Int?
  documents       Json?     @db.JsonB
  verification    String    @default("pending") @db.VarChar(20)
  verified_by     Int?
  verified_at     DateTime?
  notes           String?   @db.Text
  created_at      DateTime  @default(now())

  land Land @relation(fields: [land_id], references: [id])

  @@index([land_id])
  @@index([user_id])
  @@map("land_ownerships")
}

model PropertyLead {
  id            Int       @id @default(autoincrement())
  property_id   Int
  land_id       Int?
  lead_type     String    @default("inquiry") @db.VarChar(50)
  name          String    @db.VarChar(255)
  email         String?   @db.VarChar(255)
  phone         String?   @db.VarChar(50)
  whatsapp      String?   @db.VarChar(50)
  message       String?   @db.Text
  priority      String    @default("medium") @db.VarChar(20)
  status        String    @default("new") @db.VarChar(20)
  offer_amount  Decimal?  @db.Decimal(15, 2)
  currency      String    @default("XAF") @db.VarChar(10)
  agent_id      Int?
  user_id       Int?
  source        String?   @db.VarChar(50)
  notes         String?   @db.Text
  responded_at  DateTime?
  responded_by  Int?
  closed_at     DateTime?
  closed_reason String?   @db.VarChar(100)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([property_id])
  @@index([status])
  @@index([priority])
  @@map("property_leads")
}

model LandAuditLog {
  id           Int      @id @default(autoincrement())
  land_id      Int
  action       String   @db.VarChar(100)
  actor_id     Int?
  actor_name   String?  @db.VarChar(255)
  actor_role   String?  @db.VarChar(50)
  old_data     Json?    @db.JsonB
  new_data     Json?    @db.JsonB
  ip_address   String?  @db.VarChar(45)
  description  String?  @db.Text
  is_system    Boolean  @default(false)
  created_at   DateTime @default(now())

  land Land @relation(fields: [land_id], references: [id])

  @@index([land_id])
  @@index([action])
  @@index([created_at])
  @@map("land_audit_logs")
}

model AffiliateNetwork {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(50)
  parent_slug String?   @db.VarChar(50)
  api_base    String?   @db.VarChar(255)
  status      String    @default("active") @db.VarChar(20)
  config      Json?     @db.JsonB
  created_at  DateTime  @default(now())

  @@map("affiliate_networks")
}

model AffiliateClick {
  id            Int      @id @default(autoincrement())
  user_id       Int?
  product_id    Int?
  network       String   @db.VarChar(50)
  click_id      String   @unique @db.VarChar(255)
  subid         String?  @db.VarChar(255)
  product_url   String?  @db.Text
  ip_address    String?  @db.VarChar(45)
  user_agent    String?  @db.Text
  converted     Boolean  @default(false)
  conversion_id String?  @db.VarChar(255)
  created_at    DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([network])
  @@index([created_at])
  @@map("affiliate_clicks")
}
