generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Minimal schema for local development with SQLite
model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("user")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("users")
}

model Offer {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  url         String
  payout      Float?
  network     String?
  externalOfferId String? @unique
  networkName  String?
  trackingUrl  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  clicks      Click[]
  conversions Conversion[]

  @@map("offers")
}

model Click {
  id        Int      @id @default(autoincrement())
  offerId   Int
  clickId   String   @unique
  clickToken String   @unique
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id])

  @@index([offerId])
  @@map("clicks")
}

model Conversion {
  id        Int      @id @default(autoincrement())
  offerId   Int
  clickId   String?
  amount    Float?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id])

  @@index([offerId])
  @@map("conversions")
}
