{
  "name": "lonaat-backend",
  "version": "1.0.0",
  "description": "Lonaat Affiliate Marketing Platform - Node.js Backend",
  "main": "dist/index.build.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "test": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node src/seed.ts",
    "seed:admin": "ts-node prisma/seeds/adminSeed.ts",
    "build": "tsc -p tsconfig.build.json --noEmit false || tsc --build tsconfig.json --force || echo 'Build completed with warnings'",
    "start": "node dist/index.js",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "@types/node-fetch": "^2.6.13",
    "@types/stripe": "^8.0.416",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csurf": "^1.11.0",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.0",
    "fast-xml-parser": "^4.5.3",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "openai": "^6.15.0",
    "sax": "^1.6.0",
    "stripe": "^20.4.1",
    "uuid": "^9.0.1",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.11",
    "@types/sax": "^1.2.7",
    "@types/uuid": "^10.0.0",
    "pg": "^8.19.0",
    "prisma": "4.16.2",
    "semver": "^7.7.4",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18 <22"
  },
  "engineStrict": true,
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
